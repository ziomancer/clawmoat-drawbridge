{
  "name": "@vigil-harbor/clawmoat-drawbridge",
  "version": "1.2.0",
  "type": "module",
  "description": "Session-aware content sanitization pipeline powered by ClawMoat. Standalone library — wire into any agent pipeline.",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "clawmoat",
    "sanitizer",
    "security",
    "prompt-injection",
    "pii",
    "agent-safety",
    "session-aware"
  ],
  "author": "Vigil Harbor, LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ziomancer/clawmoat-drawbridge.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "clawmoat": ">=0.7.0"
  },
  "peerDependenciesMeta": {
    "clawmoat": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "clawmoat": "^0.7.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  }
}
